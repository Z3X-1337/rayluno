# مرجع فقط؛ التطبيق وPowerShell لا يحمّلان هذا الملف تلقائيًا.
# Reference only; the app and PowerShell do not auto-load this file.
# Never commit real API keys, purchase keys, refresh tokens, or private signing keys.

# الهوية واللغة / Identity and language
# تستخدم الأمثلة العامة بادئة RAYLUNO_. تبقى FUTURE_ASSISTANT_* aliases توافقية
# للبيتا السابقة؛ لا تضع البادئتين للقيمة نفسها إلا عند اختبار التوافق.
RAYLUNO_NAME=رايلونو
RAYLUNO_LANGUAGE=auto
RAYLUNO_WAKE_WORDS=يا رايلونو,رايلونو,Hey Rayluno,Rayluno
RAYLUNO_REQUIRE_WAKE_WORD=true

# الصوت المحلي / Local voice
RAYLUNO_WAKE_PHRASE=يا رايلونو
RAYLUNO_ENGLISH_WAKE_PHRASE=Hey Rayluno
RAYLUNO_VOSK_MODEL_PATH=C:\models\vosk-model-ar-mgb2-0.4
RAYLUNO_VOSK_ENGLISH_MODEL_PATH=C:\models\vosk-model-small-en-us-0.15
RAYLUNO_VOSK_USE_GRAMMAR=false
RAYLUNO_VOSK_ENGLISH_USE_GRAMMAR=true
RAYLUNO_WHISPER_MODEL=base
RAYLUNO_STT_BACKEND=whispercpp
RAYLUNO_WHISPER_LANGUAGE=auto
RAYLUNO_WHISPER_DEVICE=cpu
RAYLUNO_WHISPER_COMPUTE_TYPE=int8
RAYLUNO_MICROPHONE_DEVICE=
RAYLUNO_RMS_THRESHOLD=500
RAYLUNO_TTS_ENABLED=true
RAYLUNO_TTS_VOICE=

# ذكاء محلي اختياري / Optional local AI
RAYLUNO_OLLAMA_ENDPOINT=http://127.0.0.1:11434
RAYLUNO_OLLAMA_MODEL=qwen3.5:4b

# YouTube Data API اختياري بمفتاح المستخدم؛ اتركه فارغًا للعودة إلى صفحة البحث.
# Optional BYOK lookup; leave blank to use the official YouTube results page.
RAYLUNO_YOUTUBE_API_KEY=

# عنوان التفعيل الإنتاجي مثبت داخل تطبيق العميل. القيمتان التاليتان لتطوير المصدر
# فقط، وتتجاهلهما حزمة Windows المجمدة لحماية مفتاح الشراء من تحويله إلى أصل آخر.
# The production activation URL is pinned in the client. These two values are for
# source-only staging; frozen Windows builds ignore the override.
RAYLUNO_ACTIVATION_URL=
RAYLUNO_ALLOW_ACTIVATION_OVERRIDE=false

# قناة التحديث لا تُفعّل إلا بعد نشر بيان HTTPS موقّع.
# The update channel remains off until a signed HTTPS manifest is published.
RAYLUNO_UPDATE_MANIFEST_URL=

# سجل التدقيق / Audit log
# عند حذف المتغير يكون الافتراضي داخل مجلد بيانات Rayluno المحلي. قد تستخدم ترقية
# من بيتا قديمة `%LOCALAPPDATA%\FutureAssistant` حفاظًا على البيانات.
# Setting an explicitly empty value disables the audit file.
# RAYLUNO_AUDIT_PATH=C:\path\to\audit.jsonl
